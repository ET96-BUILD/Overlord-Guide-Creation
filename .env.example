# === Gemini API ===
SOPGEN_GEMINI_API_KEY=AIzaSyCuS16DmkmUwbmm2uHSDIVJMUUAKYNaSRQ
SOPGEN_GEMINI_MODEL=gemini-2.0-flash

# === Media Processing ===
# "low" saves tokens/latency; "default" improves fine text reading
SOPGEN_GEMINI_MEDIA_RESOLUTION=default
# Optional: override default 1 FPS video sampling (e.g. 2 for 2 FPS)
# SOPGEN_GEMINI_VIDEO_FPS_OVERRIDE=

# === Validation ===
SOPGEN_MAX_RETRY_ATTEMPTS=2
SOPGEN_MAX_SUBSTEPS_PER_STEP=4
SOPGEN_MIN_IMAGES_PER_STEP=1

# === Storage ===
SOPGEN_DATA_DIR=./data
SOPGEN_MAX_INLINE_SIZE_MB=20

# === Server ===
SOPGEN_API_HOST=0.0.0.0
SOPGEN_API_PORT=8000

# === FFmpeg ===
SOPGEN_FFMPEG_PATH=ffmpeg
